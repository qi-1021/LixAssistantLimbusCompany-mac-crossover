{
    "wait_tips_disappear":{
        "recognition":"template_match",
        "action":"wait_disappear",
        "params":{
            "template":"loading_tips"
        },
        "next":[
        ],
        "interrupt":[

        ]
    },
    "enter_enkephalin":{
        "recognition":"template_match",
        "action":"main_window_confirm",
        "params":{
            "template":"main_window_no_text",
            "threshold": 0.82
        },
        "next":[
            "check_language"
        ]
    },
    "check_language":{
        "action":"game_language_confirm",
        "next":[
            "check_enkephalin"
        ]
    },
    "check_enkephalin":{
        "recognition":"template_match",
        "action":"open_enkephalin_purchase",
        "inverse": true,
        "params":{
            "template":"charge_enkephalin",
            "threshold": 0.75,
            "target":[
                390,
                650
            ],
            "post_delay":1
        },
        "next":[
            "check_enkephalin",
            "recharge_enkephalin",
            "get_enkephalin_module"
        ]
    },
    "recharge_enkephalin":{
        "recognition":"template_match",
        "action":"recharge_enkephalin",
        "params":{
            "template":"charge_enkephalin"
        },
        "next":[
            "recharge_enkephalin_check"
        ]
    },
    "recharge_enkephalin_check":{
        "type":"check",
        "action": "check_out_update",
        "params":{
            "disable_node":"recharge_enkephalin",
            "execute_count": 0,
            "target_count": 1
        },
        "next":[
            "get_enkephalin_module"
        ]
    },
    "get_enkephalin_module":{
        "recognition":"template_match",
        "action":"get_enkephalin_module",
        "params":{
            "template":"charge_enkephalin"
        },
        "next":[

        ],
        "interrupt":[
            
        ]
    },
    "wait_connecting_disappear":{
        "recognition":"template_match",
        "params":{
            "template":"connecting",
            "mask":[1000, 0, 300, 200]
        },
        "next":[
            "error_handler"
        ]
    },
    "choose_team":{
        "action":"choose_team"
    },
    "ready_to_battle":{
        "action":"ready_to_battle"
    },
    "main_drive_confirm":{
        "recognition":"template_match",
